-- KEYBIND
function OlympusUI:_AddKeybind(parent, options)
    options = options or {}
    local theme = self.Theme
    local currentKey = options.Value or "None"
    local listening = false

    local frame = MakeElementFrame(parent, theme, 42)
    Utility.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = frame })

    Utility.Create("TextLabel", {
        Text = options.Title or "Keybind",
        TextColor3 = theme.Text,
        TextSize = 13,
        Font = Enum.Font.GothamSemibold,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.6, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 4,
        Parent = frame,
    })

    local keyLabel = Utility.Create("TextButton", {
        Text = "[" .. currentKey .. "]",
        TextColor3 = theme.Accent,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        BackgroundColor3 = theme.SurfaceAlt,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 70, 0, 26),
        Position = UDim2.new(1, -70, 0.5, -13),
        ZIndex = 5,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = keyLabel })

    keyLabel.MouseButton1Click:Connect(function()
        listening = true
        keyLabel.Text = "..."
        keyLabel.TextColor3 = theme.Yellow or Color3.fromHex("#ffcc00")
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if listening and not processed then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                currentKey = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
                keyLabel.Text = "[" .. currentKey .. "]"
                keyLabel.TextColor3 = theme.Accent
                listening = false
                if options.Callback then pcall(options.Callback, currentKey) end
                if options.Flag then self._Flags[options.Flag] = currentKey end
            end
        end
    end)

    local KeyAPI = {}
    function KeyAPI:Set(v)
        currentKey = v
        keyLabel.Text = "[" .. v .. "]"
    end
    function KeyAPI:Get() return currentKey end

    return KeyAPI
end

-- ============================================================
-- EXECUTOR DETECTION
-- ============================================================
function OlympusUI:DetectExecutor()
    local name = "Unknown"
    if identifyexecutor then name = identifyexecutor()
    elseif getexecutorname then name = getexecutorname()
    elseif executor then name = tostring(executor) end

    local colors = {
        flux = "#30ff6a", delta = "#e74c3c", arceus = "#a03cff",
        krampus = "#ff3838", oxygen = "#ff3838", volcano = "#ff8c00",
        synapse = "#ffd700", krypton = "#ffd700", wave = "#00e5ff",
        zenith = "#ff00ff", seliware = "#00ffa2", krnl = "#1e90ff",
        trigon = "#ff007f", nihon = "#8a2be2", celery = "#4caf50",
        lunar = "#8080ff", valyse = "#ff1493", vega = "#4682b4",
        electron = "#7fffd4", awp = "#ff005e", bunni = "#ff69b4",
    }

    local color = Color3.fromHex("#aaaaaa")
    for keyword, hex in pairs(colors) do
        if name:lower():find(keyword) then
            color = Color3.fromHex(hex)
            break
        end
    end

    return name, color
end

