        BackgroundTransparency = 1,
        Size = UDim2.new(0.2, 0, 0, 18),
        Position = UDim2.new(0.8,0,0,0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 4,
        Parent = frame,
    })

    local track = Utility.Create("Frame", {
        BackgroundColor3 = theme.Border,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 24),
        Size = UDim2.new(1, 0, 0, 8),
        ZIndex = 4,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = track })

    local fill = Utility.Create("Frame", {
        BackgroundColor3 = options.Color or theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(value / 100, 0, 1, 0),
        ZIndex = 5,
        Parent = track,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = fill })

    local ProgressAPI = {}
    function ProgressAPI:Set(v)
        value = math.clamp(v, 0, 100)
        Utility.Tween(fill, { Size = UDim2.new(value/100, 0, 1, 0) }, 0.3)
        percentLabel.Text = tostring(math.floor(value)) .. "%"
    end
    function ProgressAPI:Get() return value end

    return ProgressAPI
end

-- PARAGRAPH
function OlympusUI:_AddParagraph(parent, options)
    options = options or {}
    local theme = self.Theme

    local frame = MakeElementFrame(parent, theme, nil)
    Utility.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = frame })

    if options.Title then
        Utility.Create("TextLabel", {
            Text = options.Title,
            TextColor3 = theme.Text,
            TextSize = options.TextSize or 14,
            Font = Enum.Font.GothamBold,
            BackgroundTransparency = 1,
            Size = UDim2.new(1,0,0,0),
            AutomaticSize = Enum.AutomaticSize.Y,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            ZIndex = 4,
            Parent = frame,
        })
    end

    local descLabel
    if options.Desc then
        descLabel = Utility.Create("TextLabel", {
            Text = options.Desc,
            TextColor3 = theme.TextSub,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            BackgroundTransparency = 1,
            Size = UDim2.new(1,0,0,0),
            AutomaticSize = Enum.AutomaticSize.Y,
            Position = UDim2.new(0,0,0, options.Title and 22 or 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            ZIndex = 4,
            Parent = frame,
        })
    end

    local ParagraphAPI = {}
    function ParagraphAPI:SetTitle(t)
        for _, c in ipairs(frame:GetChildren()) do
            if c:IsA("TextLabel") and c.Font == Enum.Font.GothamBold then
                c.Text = t
            end
        end
    end
    function ParagraphAPI:SetDesc(d)
        if descLabel then descLabel.Text = d end
    end

    return ParagraphAPI
end

