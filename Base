-- TOGGLE
function OlympusUI:_AddToggle(parent, options)
    options = options or {}
    local theme = self.Theme

    local frame = MakeElementFrame(parent, theme, 42)
    Utility.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = frame })

    local value = options.Value or false
    local isCheckbox = options.Type == "Checkbox"

    Utility.Create("TextLabel", {
        Text = options.Title or "Toggle",
        TextColor3 = theme.Text,
        TextSize = 13,
        Font = Enum.Font.GothamSemibold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0.7, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 4,
        Parent = frame,
    })

    local toggleHolder, toggleCircle, checkMark

    if isCheckbox then
        toggleHolder = Utility.Create("Frame", {
            BackgroundColor3 = value and theme.Toggle or theme.ToggleOff,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 20, 0, 20),
            Position = UDim2.new(1, -20, 0.5, -10),
            ZIndex = 4,
            Parent = frame,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(0,5), Parent = toggleHolder })
        Utility.Create("UIStroke", { Color = theme.Border, Parent = toggleHolder })

        checkMark = Utility.Create("TextLabel", {
            Text = "РюЊ",
            TextColor3 = Color3.fromHex("#ffffff"),
            TextSize = 14,
            Font = Enum.Font.GothamBold,
            BackgroundTransparency = 1,
            Size = UDim2.new(1,0,1,0),
            TextXAlignment = Enum.TextXAlignment.Center,
            ZIndex = 5,
            Visible = value,
            Parent = toggleHolder,
        })
    else
        toggleHolder = Utility.Create("Frame", {
            BackgroundColor3 = value and theme.Toggle or theme.ToggleOff,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 40, 0, 22),
            Position = UDim2.new(1, -40, 0.5, -11),
            ZIndex = 4,
            Parent = frame,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = toggleHolder })

        toggleCircle = Utility.Create("Frame", {
            BackgroundColor3 = Color3.fromHex("#ffffff"),
            BorderSizePixel = 0,
            Size = UDim2.new(0, 16, 0, 16),
            Position = value and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
            ZIndex = 5,
            Parent = toggleHolder,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = toggleCircle })
    end

    if options.Desc then
        frame.Size = UDim2.new(1,0,0,58)
        Utility.Create("TextLabel", {
            Text = options.Desc,
            TextColor3 = theme.TextSub,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            BackgroundTransparency = 1,
            Position = UDim2.new(0,0,0,24),
            Size = UDim2.new(0.7,0,0,16),
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 4,
            Parent = frame,
        })
    end

    local function setToggle(v, noCallback)
        value = v
        if isCheckbox then
            Utility.Tween(toggleHolder, { BackgroundColor3 = v and theme.Toggle or theme.ToggleOff }, 0.15)
            checkMark.Visible = v
        else
            Utility.Tween(toggleHolder, { BackgroundColor3 = v and theme.Toggle or theme.ToggleOff }, 0.15)
            Utility.Tween(toggleCircle, {
                Position = v and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
            }, 0.15)
        end
        if not noCallback and options.Callback then
            pcall(options.Callback, v)
        end
        if options.Flag then
            self._Flags[options.Flag] = v
        end
    end

    local clickArea = Utility.Create("TextButton", {
        Text = "", BackgroundTransparency = 1,
        Size = UDim2.new(1,0,1,0),
        ZIndex = 6, Parent = frame,
    })
    clickArea.MouseButton1Click:Connect(function()
        setToggle(not value)
    end)

    local ToggleAPI = {}
