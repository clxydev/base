                self.ThemeName = themeName
                self.Theme = OlympusUI.Themes[themeName]
                themePopup:Destroy()
                themePopup = nil
                -- Rebuild window with new theme (simple re-color)
                self:_ApplyTheme()
            end)
        end
    end)

