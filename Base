    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            Utility.Tween(window, { Size = UDim2.fromOffset(self.Size.X.Offset, 44) }, 0.3)
            Utility.Tween(shadow, { Size = UDim2.fromOffset(self.Size.X.Offset + 40, 84) }, 0.3)
        else
            Utility.Tween(window, { Size = self.Size }, 0.3)
            Utility.Tween(shadow, { Size = UDim2.fromOffset(self.Size.X.Offset + 40, self.Size.Y.Offset + 40) }, 0.3)
        end
    end)

    -- Close
    closeBtn.MouseButton1Click:Connect(function()
        Utility.Tween(window, { Size = UDim2.fromOffset(self.Size.X.Offset, 0) }, 0.2)
        task.wait(0.22)
        gui:Destroy()
    end)

    -- Toggle key
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == self._ToggleKey then
            self._Open = not self._Open
            window.Visible = self._Open
            shadow.Visible = self._Open
        end
    end)

    table.insert(OlympusUI.Windows, self)
    return self
end

-- Apply theme colors to all elements
function OlympusUI:_ApplyTheme()
    local t = self.Theme
    if not self._Window then return end
    self._Window.BackgroundColor3 = t.Background
    -- Re-color is complex for full rebuild; just notify user
    self:Notify({
        Title = "Theme Changed",
        Content = "Switched to " .. self.ThemeName .. " theme. Reload for full effect.",
        Duration = 3,
        Theme = self.ThemeName,
    })
end

function OlympusUI:SetToggleKey(key)
    self._ToggleKey = key
end

