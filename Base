-- SLIDER
function OlympusUI:_AddSlider(parent, options)
    options = options or {}
    local theme = self.Theme
    local valConfig = options.Value or { Min = 0, Max = 100, Default = 50 }

    local minVal = valConfig.Min or 0
    local maxVal = valConfig.Max or 100
    local defVal = valConfig.Default or minVal
    local step   = options.Step or 1
    local currentVal = defVal

    local frame = MakeElementFrame(parent, theme, options.Desc and 70 or 58)
    Utility.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = frame })

    Utility.Create("TextLabel", {
        Text = options.Title or "Slider",
        TextColor3 = theme.Text,
        TextSize = 13,
        Font = Enum.Font.GothamSemibold,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.6, 0, 0, 18),
        Position = UDim2.new(0,0,0,0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 4,
        Parent = frame,
    })

    local valueLabel = Utility.Create("TextLabel", {
        Text = tostring(currentVal),
        TextColor3 = theme.Accent,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.4, 0, 0, 18),
        Position = UDim2.new(0.6,0,0,0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 4,
        Parent = frame,
    })

    if options.Desc then
        Utility.Create("TextLabel", {
            Text = options.Desc,
            TextColor3 = theme.TextSub,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            BackgroundTransparency = 1,
            Size = UDim2.new(1,0,0,14),
            Position = UDim2.new(0,0,0,20),
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 4,
            Parent = frame,
        })
    end

    local trackY = options.Desc and 40 or 28
    local track = Utility.Create("Frame", {
        BackgroundColor3 = theme.Border,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, trackY),
        Size = UDim2.new(1, 0, 0, 6),
        ZIndex = 4,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = track })

    local fill = Utility.Create("Frame", {
        BackgroundColor3 = theme.Slider,
        BorderSizePixel = 0,
        Size = UDim2.new((defVal - minVal) / (maxVal - minVal), 0, 1, 0),
        ZIndex = 5,
        Parent = track,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = fill })

    local thumb = Utility.Create("Frame", {
        BackgroundColor3 = Color3.fromHex("#ffffff"),
        BorderSizePixel = 0,
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new((defVal - minVal) / (maxVal - minVal), -7, 0.5, -7),
        ZIndex = 6,
        Parent = track,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = thumb })

    local tooltip = nil
    if options.IsTooltip then
        tooltip = Utility.Create("TextLabel", {
            Text = tostring(defVal),
            TextColor3 = Color3.fromHex("#ffffff"),
            TextSize = 11,
            Font = Enum.Font.GothamBold,
            BackgroundColor3 = theme.Accent,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 32, 0, 20),
            AnchorPoint = Vector2.new(0.5, 1),
            Position = UDim2.new((defVal - minVal) / (maxVal - minVal), 0, 0, -6),
            ZIndex = 7,
            Visible = false,
            Parent = track,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(0,4), Parent = tooltip })
    end

    -- Dragging
    local dragging = false

    local function updateSlider(absPos)
        local trackAbsPos = track.AbsolutePosition.X
        local trackAbsSize = track.AbsoluteSize.X
        local ratio = math.clamp((absPos - trackAbsPos) / trackAbsSize, 0, 1)
        local rawVal = minVal + (maxVal - minVal) * ratio
        local snapped = math.floor(rawVal / step + 0.5) * step
        snapped = math.clamp(snapped, minVal, maxVal)
        currentVal = snapped

        local displayRatio = (currentVal - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(displayRatio, 0, 1, 0)
        thumb.Position = UDim2.new(displayRatio, -7, 0.5, -7)
        valueLabel.Text = tostring(currentVal)

        if tooltip then
            tooltip.Text = tostring(currentVal)
            tooltip.Position = UDim2.new(displayRatio, 0, 0, -6)
        end

        if options.Callback then pcall(options.Callback, currentVal) end
        if options.Flag then self._Flags[options.Flag] = currentVal end
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            if tooltip then tooltip.Visible = true end
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            if tooltip then tooltip.Visible = false end
        end
    end)

    local SliderAPI = {}
    function SliderAPI:Set(v)
        currentVal = math.clamp(v, minVal, maxVal)
        local r = (currentVal - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(r, 0, 1, 0)
        thumb.Position = UDim2.new(r, -7, 0.5, -7)
        valueLabel.Text = tostring(currentVal)
    end
    function SliderAPI:Get() return currentVal end

    return SliderAPI
end

