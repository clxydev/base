local NotifyContainer = nil

local function EnsureNotifyContainer()
    if NotifyContainer and NotifyContainer.Parent then return end
    local gui = CoreGui:FindFirstChild("OlympusUI_Notify")
    if gui then gui:Destroy() end

    gui = Utility.Create("ScreenGui", {
        Name = "OlympusUI_Notify",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 9999,
    })

    pcall(function() gui.Parent = CoreGui end)
    if not gui.Parent then gui.Parent = PlayerGui end

    NotifyContainer = Utility.Create("Frame", {
        Name = "Container",
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -20, 1, -20),
        AnchorPoint = Vector2.new(1, 1),
        Size = UDim2.new(0, 320, 1, -20),
        Parent = gui,
    })

    Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        Padding = UDim.new(0, 8),
        Parent = NotifyContainer,
    })
end

function OlympusUI:Notify(options)
    options = options or {}
    local theme = OlympusUI.Themes[options.Theme or "Dark"]

    EnsureNotifyContainer()

    local title    = options.Title or "OlympusUI"
    local content  = options.Content or ""
    local duration = options.Duration or 4
    local icon     = options.Icon or "bell"
    local color    = options.Color or theme.NotifyBorder

    -- Frame
    local notifFrame = Utility.Create("Frame", {
        Name = "Notification",
        BackgroundColor3 = theme.Surface,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 0,
        Parent = NotifyContainer,
    })

    Utility.Create("UICorner",   { CornerRadius = UDim.new(0, 10), Parent = notifFrame })
    Utility.Create("UIStroke",   { Color = color, Thickness = 1.5, Parent = notifFrame })
    Utility.Create("UIPadding",  { PaddingLeft = UDim.new(0,12), PaddingRight = UDim.new(0,12), PaddingTop = UDim.new(0,10), PaddingBottom = UDim.new(0,10), Parent = notifFrame })

    -- Accent bar
    Utility.Create("Frame", {
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 3, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        Parent = notifFrame,
    })

    local contentFrame = Utility.Create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -10, 0, 0),
        Position = UDim2.new(0, 10, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = notifFrame,
    })

    Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 3),
        Parent = contentFrame,
    })

    Utility.Create("TextLabel", {
        Text = title,
        TextColor3 = theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 18),
        TextXAlignment = Enum.TextXAlignment.Left,
        LayoutOrder = 1,
        Parent = contentFrame,
    })

    if content ~= "" then
        Utility.Create("TextLabel", {
            Text = content,
            TextColor3 = theme.TextSub,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            LayoutOrder = 2,
            Parent = contentFrame,
        })
    end

    -- Progress bar
    local progressBG = Utility.Create("Frame", {
        BackgroundColor3 = theme.Border,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        Parent = notifFrame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = progressBG })

    local progressBar = Utility.Create("Frame", {
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = progressBG,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = progressBar })

    -- Animate in
    notifFrame.BackgroundTransparency = 1
    Utility.Tween(notifFrame, { BackgroundTransparency = 0 }, 0.3)

    -- Progress animation
    Utility.Tween(progressBar, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

    -- Auto dismiss
    task.delay(duration, function()
        Utility.Tween(notifFrame, { BackgroundTransparency = 1 }, 0.3)
        task.wait(0.35)
        notifFrame:Destroy()
    end)
end

