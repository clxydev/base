        LayoutOrder = #self._Tabs + 1,
        Parent = self._SidebarList,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 8), Parent = tabBtn })

    local tabLabel = Utility.Create("TextLabel", {
        Text = tabData.Title,
        TextColor3 = theme.TextSub,
        TextSize = 13,
        Font = Enum.Font.GothamSemibold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -20, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 5,
        Parent = tabBtn,
    })

    -- Badge
    if tabData.Badge then
        local badge = Utility.Create("TextLabel", {
            Text = tabData.Badge,
            TextColor3 = Color3.fromHex("#ffffff"),
            TextSize = 9,
            Font = Enum.Font.GothamBold,
            BackgroundColor3 = theme.Accent,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 0, 0, 16),
            AutomaticSize = Enum.AutomaticSize.X,
            Position = UDim2.new(1, -8, 0.5, -8),
            AnchorPoint = Vector2.new(1, 0.5),
            ZIndex = 6,
            Parent = tabBtn,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(1,0), Parent = badge })
        Utility.Create("UIPadding", {
            PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
            Parent = badge,
        })
    end

    -- Content page (ScrollingFrame)
    local page = Utility.Create("ScrollingFrame", {
        Name = "Page_" .. tabData.Title,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 1, 0),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = theme.Border,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y,
        Visible = false,
        ZIndex = 3,
        Parent = self._Content,
    })

    local pageList = Utility.Create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = page,
    })
    Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
        Parent = pageList,
    })
    Utility.Create("UIPadding", {
        PaddingTop = UDim.new(0,12),
        PaddingLeft = UDim.new(0,12),
        PaddingRight = UDim.new(0,12),
        PaddingBottom = UDim.new(0,12),
        Parent = pageList,
    })

    tabData._Btn      = tabBtn
    tabData._Label    = tabLabel
    tabData._Page     = page
    tabData._PageList = pageList

    -- Click handler
    tabBtn.MouseButton1Click:Connect(function()
        self:_SelectTab(tabData)
    end)

    -- Hover
    tabBtn.MouseEnter:Connect(function()
        if self._ActiveTab ~= tabData then
            Utility.Tween(tabBtn, { BackgroundTransparency = 0.85 }, 0.15)
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if self._ActiveTab ~= tabData then
            Utility.Tween(tabBtn, { BackgroundTransparency = 1 }, 0.15)
        end
    end)

    table.insert(self._Tabs, tabData)

    -- Auto-select first tab
    if #self._Tabs == 1 then
        self:_SelectTab(tabData)
    end

    -- Return element API
    local TabAPI = {}
    TabAPI._data = tabData
    TabAPI._window = self

    function TabAPI:Section(opts) return self._window:_AddSection(tabData._PageList, opts, self._window) end
    function TabAPI:Button(opts) return self._window:_AddButton(tabData._PageList, opts) end
    function TabAPI:Toggle(opts) return self._window:_AddToggle(tabData._PageList, opts) end
    function TabAPI:Slider(opts) return self._window:_AddSlider(tabData._PageList, opts) end
    function TabAPI:Input(opts) return self._window:_AddInput(tabData._PageList, opts) end
    function TabAPI:Dropdown(opts) return self._window:_AddDropdown(tabData._PageList, opts) end
    function TabAPI:Colorpicker(opts) return self._window:_AddColorpicker(tabData._PageList, opts) end
    function TabAPI:ProgressBar(opts) return self._window:_AddProgressBar(tabData._PageList, opts) end
    function TabAPI:Paragraph(opts) return self._window:_AddParagraph(tabData._PageList, opts) end
    function TabAPI:Divider() return self._window:_AddDivider(tabData._PageList) end
    function TabAPI:Space() return self._window:_AddSpace(tabData._PageList) end
    function TabAPI:Keybind(opts) return self._window:_AddKeybind(tabData._PageList, opts) end

    return TabAPI
end

function OlympusUI:_SelectTab(tabData)
    -- Deselect all
    for _, t in ipairs(self._Tabs) do
        t._Page.Visible = false
        Utility.Tween(t._Btn, { BackgroundTransparency = 1 }, 0.15)
        Utility.Tween(t._Label, { TextColor3 = self.Theme.TextSub }, 0.15)
    end

    -- Select target
    tabData._Page.Visible = true
    Utility.Tween(tabData._Btn, { BackgroundTransparency = 0, BackgroundColor3 = self.Theme.Accent }, 0.15)
    Utility.Tween(tabData._Label, { TextColor3 = Color3.fromHex("#ffffff") }, 0.15)
    self._ActiveTab = tabData
end

