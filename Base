    })

    local arrow = Utility.Create("TextLabel", {
        Text = "РќЙ",
        TextColor3 = theme.TextSub,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -20, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 12,
        Parent = header,
    })

    local selectedLabel = Utility.Create("TextLabel", {
        Text = "None",
        TextColor3 = theme.Accent,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.55, 0, 1, 0),
        Position = UDim2.new(0.4, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 12,
        Parent = header,
    })

    -- List container
    local listContainer = Utility.Create("ScrollingFrame", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 42),
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = theme.Border,
        CanvasSize = UDim2.new(0,0,0,0),
        AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y,
        ClipsDescendants = true,
        ZIndex = 12,
        Visible = false,
        Parent = frame,
    })
    Utility.Create("UIPadding", {
        PaddingLeft = UDim.new(0,8), PaddingRight = UDim.new(0,8),
        PaddingBottom = UDim.new(0,6),
        Parent = listContainer,
    })
    Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,3),
        Parent = listContainer,
    })

    local function updateSelectedLabel()
        local parts = {}
        for v, _ in pairs(selected) do
            table.insert(parts, tostring(type(v)=="table" and v.Title or v))
        end
        selectedLabel.Text = #parts > 0 and table.concat(parts, ", ") or "None"
    end

    local function refreshItems()
        for _, c in ipairs(listContainer:GetChildren()) do
            if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end
        end

        for _, val in ipairs(values) do
            local isAdvanced = type(val) == "table" and val.Title
            local displayText = isAdvanced and val.Title or tostring(val)
            local isDivider = isAdvanced and val.Type == "Divider"

            if isDivider then
                local div = Utility.Create("Frame", {
                    BackgroundColor3 = theme.Border,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 1),
                    ZIndex = 13,
                    Parent = listContainer,
                })
            else
                local key = isAdvanced and val.Title or val
                local itemBtn = Utility.Create("TextButton", {
                    Text = displayText,
                    TextColor3 = selected[key] and theme.Accent or theme.Text,
                    TextSize = 12,
                    Font = Enum.Font.GothamSemibold,
                    BackgroundColor3 = selected[key] and theme.SurfaceAlt or theme.Surface,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 28),
                    ZIndex = 13,
                    Parent = listContainer,
                })
                Utility.Create("UICorner", { CornerRadius = UDim.new(0,6), Parent = itemBtn })

                itemBtn.MouseButton1Click:Connect(function()
                    if multi then
                        if selected[key] then
                            selected[key] = nil
                        else
                            selected[key] = true
                        end
                    else
                        selected = {}
                        selected[key] = true
                    end
                    updateSelectedLabel()
                    refreshItems()

                    if options.Callback then
                        if multi then
                            local t = {}
                            for k,_ in pairs(selected) do table.insert(t, k) end
                            pcall(options.Callback, t)
                        else
                            pcall(options.Callback, isAdvanced and val or key)
                        end
                    end
                    if options.Flag then
                        if multi then
                            local t = {}
                            for k,_ in pairs(selected) do table.insert(t, k) end
                            self._Flags[options.Flag] = t
                        else
                            self._Flags[options.Flag] = key
                        end
                    end

                    if not multi then
                        open = false
                        Utility.Tween(listContainer, { Size = UDim2.new(1,0,0,0) }, 0.2)
                        task.wait(0.2)
                        listContainer.Visible = false
                    end
                end)

                itemBtn.MouseEnter:Connect(function()
                    if not selected[key] then
                        Utility.Tween(itemBtn, { BackgroundColor3 = theme.SurfaceAlt }, 0.1)
                    end
                end)
                itemBtn.MouseLeave:Connect(function()
                    if not selected[key] then
                        Utility.Tween(itemBtn, { BackgroundColor3 = theme.Surface }, 0.1)
                    end
                end)
            end
        end
    end

    refreshItems()
    updateSelectedLabel()

    -- Toggle open
    local headerBtn = Utility.Create("TextButton", {
        Text = "", BackgroundTransparency = 1,
        Size = UDim2.new(1,0,0,42),
        ZIndex = 14,
        Parent = frame,
    })

    headerBtn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            listContainer.Visible = true
            local itemCount = math.min(#values, 6)
            local targetHeight = itemCount * 31 + 6
            Utility.Tween(listContainer, { Size = UDim2.new(1,0,0,targetHeight) }, 0.2)
            Utility.Tween(arrow, { Rotation = 180 }, 0.2)
        else
            Utility.Tween(listContainer, { Size = UDim2.new(1,0,0,0) }, 0.2)
            Utility.Tween(arrow, { Rotation = 0 }, 0.2)
            task.wait(0.2)
            listContainer.Visible = false
        end
    end)

    local DropAPI = {}
    function DropAPI:Refresh(newValues)
        values = newValues
        refreshItems()
        updateSelectedLabel()
    end
    function DropAPI:Select(v)
        selected = {}
        if type(v) == "table" then
            for _, k in ipairs(v) do selected[k] = true end
        else
            selected[v] = true
        end
        updateSelectedLabel()
        refreshItems()
    end
    function DropAPI:Get() return selected end

    return DropAPI
end

