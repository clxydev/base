local function GetIcon(name)
    if not name or name=="" then return nil end
    if name:sub(1,13)=="rbxassetid://" then return name end
    return Icons[name:lower()]
end

local function MakeIcon(name, sz, col, parent)
    local id = GetIcon(name)
    sz = sz or 16
    if id then
        return New("ImageLabel",{
            Size=UDim2.fromOffset(sz,sz),BackgroundTransparency=1,
            Image=id,ImageColor3=col or Color3.new(1,1,1),
            ScaleType=Enum.ScaleType.Fit,Parent=parent
        })
    else
        return New("TextLabel",{
            Size=UDim2.fromOffset(sz,sz),BackgroundTransparency=1,
            Text=name and name:sub(1,1):upper() or "•",
            TextColor3=col or Color3.new(1,1,1),
            TextSize=sz*.75,Font=Enum.Font.GothamBold,Parent=parent
        })
    end
end

