        -- ── DROPDOWN ────────────────────────────────────────
        function Tab:Dropdown(c3)
            c3=c3 or {}
            local vals=c3.Values or {}
            local sel=c3.Value
            local multi=c3.Multi or false
            local msel={}
            local open=false

            local f=EF(page,36); Pad(0,0,12,12,f)
            local hdr=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,Parent=f})
            List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,8,hdr)
            if c3.Icon then MakeIcon(c3.Icon,15,theme.Accent,hdr) end
            New("TextLabel",{
                Size=UDim2.new(1,-82,1,0),BackgroundTransparency=1,Text=c3.Title or "Dropdown",
                TextColor3=theme.Text,TextSize=13,Font=Enum.Font.GothamSemibold,
                TextXAlignment=Enum.TextXAlignment.Left,Parent=hdr
            })
            local slbl=New("TextLabel",{
                Size=UDim2.fromOffset(72,36),BackgroundTransparency=1,
                Text=multi and "None" or (tostring(sel or "Select")),
                TextColor3=theme.TextMuted,TextSize=11,Font=Enum.Font.Gotham,
                TextXAlignment=Enum.TextXAlignment.Right,TextTruncate=Enum.TextTruncate.AtEnd,Parent=hdr
            })

            local panel=New("Frame",{
                Size=UDim2.new(1,0,0,0),BackgroundColor3=theme.SurfaceAlt,
                ClipsDescendants=true,LayoutOrder=99,Parent=f
            })
            Corner(8,panel); Stroke(1,theme.Border,0,panel); Pad(4,4,4,4,panel)
            local pL=List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Top,2,panel)

            local function glbl(v) return type(v)=="table" and (v.Title or tostring(v)) or tostring(v) end

            local function build()
                for _,c in ipairs(panel:GetChildren()) do if c:IsA("TextButton") or c:IsA("Frame") and c~=panel then c:Destroy() end end
                for i,v in ipairs(vals) do
                    if type(v)=="table" and v.Type=="Divider" then
                        New("Frame",{Size=UDim2.new(1,-8,0,1),BackgroundColor3=theme.Border,BorderSizePixel=0,LayoutOrder=i,Parent=panel})
                    else
                        local lbl=glbl(v)
                        local item=New("TextButton",{
                            Size=UDim2.new(1,0,0,28),BackgroundColor3=theme.SurfaceAlt,
                            BackgroundTransparency=1,Text="",LayoutOrder=i,Parent=panel
                        })
                        Corner(6,item); Pad(0,0,8,8,item)
                        List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,6,item)
                        if type(v)=="table" and v.Icon then MakeIcon(v.Icon,13,theme.TextMuted,item) end
                        local isSel=multi and msel[lbl] or (sel==lbl)
                        local ilbl=New("TextLabel",{
                            Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=lbl,
                            TextColor3=isSel and theme.Accent or theme.Text,
                            TextSize=12,Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                            TextXAlignment=Enum.TextXAlignment.Left,Parent=item
                        })
                        item.MouseEnter:Connect(function() Tween(item,{BackgroundTransparency=0,BackgroundColor3=theme.TabHover},0.1) end)
                        item.MouseLeave:Connect(function() Tween(item,{BackgroundTransparency=1},0.1) end)
                        item.MouseButton1Click:Connect(function()
                            if multi then
                                msel[lbl]=not msel[lbl]
                                ilbl.TextColor3=msel[lbl] and theme.Accent or theme.Text
                                ilbl.Font=msel[lbl] and Enum.Font.GothamBold or Enum.Font.Gotham
                                local s2={}
                                for k,sv in pairs(msel) do if sv then table.insert(s2,k) end end
                                slbl.Text=#s2>0 and table.concat(s2,", ") or "None"
                                if c3.Callback then c3.Callback(s2) end
                            else
                                sel=lbl; slbl.Text=lbl
                                if c3.Callback then c3.Callback(type(v)=="table" and v or lbl) end
                                open=false
                                Tween(panel,{Size=UDim2.new(1,0,0,0)},0.2)
                                Tween(f,{Size=UDim2.new(1,0,0,36)},0.2)
                                build()
                            end
                        end)
                    end
                end
            end
            build()

            local cl=New("TextButton",{Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,Text="",ZIndex=f.ZIndex+1,Parent=hdr})
            cl.MouseButton1Click:Connect(function()
                open=not open
                if open then
                    build()
                    task.wait()
                    local ph=pL.AbsoluteContentSize.Y+8
                    Tween(panel,{Size=UDim2.new(1,0,0,ph)},0.25)
                    Tween(f,{Size=UDim2.new(1,0,0,36+ph+4)},0.25)
                else
                    Tween(panel,{Size=UDim2.new(1,0,0,0)},0.2)
                    Tween(f,{Size=UDim2.new(1,0,0,36)},0.2)
                end
            end)

            local obj={}
            function obj:Refresh(nv) vals=nv; build() end
            function obj:Select(v)
                if multi then for _,sv in ipairs(v) do msel[sv]=true end
                else sel=tostring(v); slbl.Text=tostring(v) end
            end
            function obj:Get()
                if multi then local s2={};for k,sv in pairs(msel) do if sv then table.insert(s2,k) end end; return s2 end
                return sel
            end
            return obj
        end

