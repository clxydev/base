                Parent=svP
            })
            local svo=New("Frame",{Size=UDim2.fromScale(1,1),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=0,Parent=svP})
            Corner(6,svo)
            New("UIGradient",{
                Color=ColorSequence.new(Color3.fromRGB(255,255,255),Color3.fromRGB(0,0,0)),
                Transparency=NumberSequence.new(NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(1,0)),
                Rotation=90,Parent=svo
            })
            local svDot=New("Frame",{
                Size=UDim2.fromOffset(10,10),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(cs,0,1-cv,0),
                BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=5,Parent=svP
            })
            Corner(5,svDot); Stroke(1.5,Color3.fromRGB(0,0,0),0,svDot)

            local hBar=New("Frame",{Size=UDim2.new(1,0,0,12),Parent=panel})
            Corner(6,hBar)
            New("UIGradient",{Color=ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromHSV(0,1,1)),ColorSequenceKeypoint.new(1/6,Color3.fromHSV(1/6,1,1)),
                ColorSequenceKeypoint.new(2/6,Color3.fromHSV(2/6,1,1)),ColorSequenceKeypoint.new(3/6,Color3.fromHSV(3/6,1,1)),
                ColorSequenceKeypoint.new(4/6,Color3.fromHSV(4/6,1,1)),ColorSequenceKeypoint.new(5/6,Color3.fromHSV(5/6,1,1)),
                ColorSequenceKeypoint.new(1,Color3.fromHSV(1,1,1))
            }),Parent=hBar})
            local hDot=New("Frame",{
                Size=UDim2.fromOffset(10,12),AnchorPoint=Vector2.new(.5,0),Position=UDim2.new(ch,0,0,0),
                BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=5,Parent=hBar
            })
            Corner(4,hDot); Stroke(1,Color3.fromRGB(0,0,0),0,hDot)

            local hexBox=New("TextBox",{
                Size=UDim2.new(1,0,0,22),BackgroundColor3=theme.Surface,
                Text="#"..col:ToHex():upper(),TextColor3=theme.Text,TextSize=12,
                Font=Enum.Font.Code,TextXAlignment=Enum.TextXAlignment.Center,
                ClearTextOnFocus=false,Parent=panel
            })
            Corner(6,hexBox); Stroke(1,theme.Border,0,hexBox)

            local pL2=List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Top,6,panel)

            local function apply()
                col=Color3.fromHSV(ch,cs,cv)
                prev.BackgroundColor3=col
                svP.BackgroundColor3=Color3.fromHSV(ch,1,1)
                svDot.Position=UDim2.new(cs,0,1-cv,0)
                hDot.Position=UDim2.new(ch,0,0,0)
                hexBox.Text="#"..col:ToHex():upper()
                if c3.Callback then c3.Callback(col) end
            end

            local dSV,dH=false,false
            svP.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    dSV=true
                    cs=math.clamp((i.Position.X-svP.AbsolutePosition.X)/svP.AbsoluteSize.X,0,1)
                    cv=1-math.clamp((i.Position.Y-svP.AbsolutePosition.Y)/svP.AbsoluteSize.Y,0,1)
                    apply()
                end
            end)
            hBar.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    dH=true
                    ch=math.clamp((i.Position.X-hBar.AbsolutePosition.X)/hBar.AbsoluteSize.X,0,1)
                    apply()
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseMovement then
                    if dSV then
                        cs=math.clamp((i.Position.X-svP.AbsolutePosition.X)/svP.AbsoluteSize.X,0,1)
                        cv=1-math.clamp((i.Position.Y-svP.AbsolutePosition.Y)/svP.AbsoluteSize.Y,0,1)
                        apply()
                    elseif dH then
                        ch=math.clamp((i.Position.X-hBar.AbsolutePosition.X)/hBar.AbsoluteSize.X,0,1)
                        apply()
                    end
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then dSV=false;dH=false end
            end)
            hexBox.FocusLost:Connect(function()
                pcall(function()
                    col=Color3.fromHex(hexBox.Text:gsub("#",""))
                    ch,cs,cv=Color3.toHSV(col); apply()
                end)
            end)

            local cl=New("TextButton",{Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,Text="",ZIndex=f.ZIndex+1,Parent=f})
            cl.MouseButton1Click:Connect(function()
                open=not open
                if open then
                    task.wait()
                    local ph=pL2.AbsoluteContentSize.Y+16
                    Tween(panel,{Size=UDim2.new(1,0,0,ph)},0.25)
                    Tween(f,{Size=UDim2.new(1,0,0,36+ph+4)},0.25)
                else
                    Tween(panel,{Size=UDim2.new(1,0,0,0)},0.2)
                    Tween(f,{Size=UDim2.new(1,0,0,36)},0.2)
                end
            end)

            local obj={}
            function obj:Set(c) col=c;ch,cs,cv=Color3.toHSV(c);apply() end
            function obj:Get() return col end
            return obj
        end

