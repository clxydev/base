        })
        cb.MouseButton1Click:Connect(function()
            Tween(card,{Position=UDim2.fromOffset(320,0)},0.25)
            task.wait(0.3); card:Destroy()
        end)
    end

    task.wait()
    local h2=innerL.AbsoluteContentSize.Y+20
    card.Size=UDim2.fromOffset(300,math.max(60,h2))

    card.Position=UDim2.fromOffset(320,0)
    Tween(card,{Position=UDim2.fromOffset(0,0)},0.3)

    task.delay(cfg.Duration or 4,function()
        if card and card.Parent then
            Tween(card,{Position=UDim2.fromOffset(320,0)},0.25)
            task.wait(0.3); if card and card.Parent then card:Destroy() end
        end
    end)
end

-- ============================================================
-- CREATE WINDOW
-- ============================================================
function OlympusUI:CreateWindow(cfg)
    cfg = cfg or {}
    local themeName = cfg.Theme or "Crimson"
    local theme = Themes[themeName] or Themes.Crimson

    -- Screen GUI
    local sg = New("ScreenGui",{
        Name="OlympusUI_".. (cfg.Title or "Win"),
        ResetOnSpawn=false,ZIndexBehavior=Enum.ZIndexBehavior.Sibling,DisplayOrder=100
    })
    pcall(function() sg.Parent=CoreGui end)
    if not sg.Parent then sg.Parent=LocalPlayer.PlayerGui end

    -- Main frame
    local WSize = cfg.Size or UDim2.fromOffset(560,380)
    local mainF = New("Frame",{
        Name="Main",Size=WSize,Position=UDim2.fromScale(0.5,0.5),AnchorPoint=Vector2.new(0.5,0.5),
        BackgroundColor3=theme.Background,ClipsDescendants=true,Parent=sg
    })
    Corner(12,mainF); Stroke(1,theme.Border,0,mainF)

    -- Shadow
    New("ImageLabel",{
        Size=UDim2.new(1,40,1,40),Position=UDim2.fromOffset(-20,-20),
        BackgroundTransparency=1,Image="rbxassetid://6014261993",
        ImageColor3=theme.Shadow,ImageTransparency=0.55,
        ScaleType=Enum.ScaleType.Slice,SliceCenter=Rect.new(49,49,450,450),
        ZIndex=0,Parent=mainF
    })

    -- ── Topbar ──────────────────────────────────────────────
    local topbar = New("Frame",{
        Name="Topbar",Size=UDim2.new(1,0,0,44),
        BackgroundColor3=theme.Surface,ZIndex=2,Parent=mainF
    })
    Stroke(1,theme.Border,0,topbar)
    Drag(topbar,mainF)
    Pad(0,0,12,8,topbar)

    -- Gradient accent line
    local aLine=New("Frame",{
        Size=UDim2.new(1,0,0,2),BackgroundColor3=theme.Accent,
        BorderSizePixel=0,ZIndex=3,Parent=topbar
    })
    New("UIGradient",{Color=ColorSequence.new(theme.GradientA,theme.GradientB),Parent=aLine})

    local tl=List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,8,topbar)

    -- Icon
    if cfg.Icon then
        local ic=MakeIcon(cfg.Icon,18,theme.Accent,topbar)
        if ic then ic.LayoutOrder=0 end
    end

    -- Title
    New("TextLabel",{
        Size=UDim2.fromOffset(0,44),AutomaticSize=Enum.AutomaticSize.X,
        BackgroundTransparency=1,Text=cfg.Title or "OlympusUI",
        TextColor3=theme.Text,TextSize=15,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,Parent=topbar
    })

    if cfg.Author then
        New("TextLabel",{
            Size=UDim2.fromOffset(0,44),AutomaticSize=Enum.AutomaticSize.X,
            BackgroundTransparency=1,Text="by "..cfg.Author,
            TextColor3=theme.TextMuted,TextSize=12,Font=Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=topbar
        })
    end

    -- Flexible spacer
    New("Frame",{
        Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,LayoutOrder=90,Parent=topbar
    })

    -- Topbar buttons
    local function TBtn(icon,col,cb,lo)
        local b=New("TextButton",{
            Size=UDim2.fromOffset(28,28),BackgroundColor3=theme.SurfaceAlt,
            Text="",LayoutOrder=lo or 95,Parent=topbar
        })
        Corner(6,b)
        local ic=MakeIcon(icon,13,col,b)
        if ic then ic.AnchorPoint=Vector2.new(.5,.5);ic.Position=UDim2.fromScale(.5,.5) end
        b.MouseEnter:Connect(function() Tween(b,{BackgroundColor3=col},0.15) end)
        b.MouseLeave:Connect(function() Tween(b,{BackgroundColor3=theme.SurfaceAlt},0.15) end)
        b.MouseButton1Click:Connect(cb); return b
    end

    local isMin=false
    local bodyF

    TBtn("minus",theme.TextMuted,function()
        isMin=not isMin
        if bodyF then
            Tween(bodyF,{Size=isMin and UDim2.new(1,0,0,0) or UDim2.new(1,0,1,-44)},0.3)
        end
    end,95)

    TBtn("x",Color3.fromHex("#EF4444"),function()
        Tween(mainF,{BackgroundTransparency=1},0.2)
        task.wait(0.25); sg:Destroy()
    end,96)

    -- ── Body ────────────────────────────────────────────────
    bodyF = New("Frame",{
        Name="Body",Size=UDim2.new(1,0,1,-44),Position=UDim2.fromOffset(0,44),
        BackgroundTransparency=1,ClipsDescendants=true,Parent=mainF
    })

    -- Sidebar
    local sbW = cfg.SideBarWidth or 160
    local sidebar = New("ScrollingFrame",{
        Name="Sidebar",Size=UDim2.new(0,sbW,1,0),
        BackgroundColor3=theme.SidebarBg,BorderSizePixel=0,
        ScrollBarThickness=0,ScrollingDirection=Enum.ScrollingDirection.Y,
        CanvasSize=UDim2.fromScale(0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
        Parent=bodyF
    })
    Stroke(1,theme.Border,0,sidebar)
    Pad(8,8,6,6,sidebar)
    List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Top,4,sidebar)

    -- Search bar
    local searchBox
    if cfg.SearchBar ~= false then
        local sh=New("Frame",{
            Size=UDim2.new(1,0,0,28),BackgroundColor3=theme.SurfaceAlt,LayoutOrder=0,Parent=sidebar
        })
        Corner(7,sh); Stroke(1,theme.Border,0,sh)
        local sic=MakeIcon("search",12,theme.TextMuted,sh)
        if sic then sic.AnchorPoint=Vector2.new(0,.5);sic.Position=UDim2.new(0,6,.5,0) end
        searchBox=New("TextBox",{
            Size=UDim2.new(1,-22,1,0),Position=UDim2.fromOffset(22,0),
            BackgroundTransparency=1,Text="",PlaceholderText="Search tabs...",
            TextColor3=theme.Text,PlaceholderColor3=theme.TextDisabled,
            TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,
            ClearTextOnFocus=false,Parent=sh
        })
    end

    -- Tag holder
    local tagHolder=New("Frame",{
        Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y,
        LayoutOrder=1,Parent=sidebar
    })
    local tagL=List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,4,tagHolder)
    tagL.Wraps=true

    -- Divider
    New("Frame",{
        Size=UDim2.new(1,0,0,1),BackgroundColor3=theme.Border,
        BorderSizePixel=0,LayoutOrder=2,Parent=sidebar
    })

    -- Content
    local content=New("Frame",{
        Name="Content",Size=UDim2.new(1,-sbW,1,0),Position=UDim2.fromOffset(sbW,0),
        BackgroundColor3=theme.Background,ClipsDescendants=true,Parent=bodyF
    })

    -- Mobile open button
    if cfg.OpenButton then
        local ob=cfg.OpenButton
        local mbtn=New("TextButton",{
            Name="OpenBtn",Size=UDim2.fromOffset(120,34),
            Position=UDim2.new(0,16,1,-52),
            BackgroundColor3=theme.Accent,Text=ob.Title or "Open",
            TextColor3=theme.Text,TextSize=12,Font=Enum.Font.GothamBold,
            ZIndex=200,Visible=ob.OnlyMobile and UserInputService.TouchEnabled or (ob.Enabled ~= false),
            Parent=sg
        })
        Corner(ob.CornerRadius and ob.CornerRadius.Offset or 17,mbtn)
        if ob.StrokeThickness then Stroke(ob.StrokeThickness,theme.Accent,.3,mbtn) end
        if ob.Color then New("UIGradient",{Color=ob.Color,Rotation=90,Parent=mbtn}) end
        if ob.Draggable then Drag(mbtn,mbtn) end
        mbtn.MouseButton1Click:Connect(function() mainF.Visible=not mainF.Visible end)
    end

    -- ── Tab System ──────────────────────────────────────────
    local tabs, activeTab = {}, nil

    local function SwitchTab(tobj)
        if activeTab==tobj then return end
        if activeTab then
            Tween(activeTab._btn,{BackgroundTransparency=1},0.2)
            Tween(activeTab._titleLbl,{TextColor3=theme.TextMuted,Font=Enum.Font.Gotham},0.15)
            activeTab._page.Visible=false
        end
        activeTab=tobj
        Tween(activeTab._btn,{BackgroundColor3=theme.TabActive,BackgroundTransparency=0},0.2)
        Tween(activeTab._titleLbl,{TextColor3=theme.Text,Font=Enum.Font.GothamSemibold},0.15)
        activeTab._page.Visible=true
    end

    -- ── Window Object ────────────────────────────────────────
    local Window={}

    function Window:Tag(c2)
        c2=c2 or {}
        local t=New("Frame",{
            Size=UDim2.fromOffset(0,20),AutomaticSize=Enum.AutomaticSize.X,
            BackgroundColor3=c2.Color or theme.SurfaceAlt,LayoutOrder=#tagHolder:GetChildren(),Parent=tagHolder
        })
        Corner(c2.Radius or 10,t)
        Pad(0,0,7,7,t)
        List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,4,t)
        if c2.Icon then MakeIcon(c2.Icon,11,theme.TextMuted,t) end
        New("TextLabel",{
            Size=UDim2.fromOffset(0,20),AutomaticSize=Enum.AutomaticSize.X,
            BackgroundTransparency=1,Text=c2.Title or "",TextColor3=theme.Text,
            TextSize=11,Font=Enum.Font.GothamBold,Parent=t
        })
        if c2.Border then Stroke(1,theme.Border,0,t) end
    end

    function Window:Tab(c2)
        c2=c2 or {}
        local lo=#tabs+10

        -- Sidebar button
        local btn=New("TextButton",{
            Size=UDim2.new(1,0,0,32),BackgroundColor3=theme.TabActive,
            BackgroundTransparency=1,Text="",LayoutOrder=lo,Parent=sidebar
        })
        Corner(7,btn); Pad(0,0,8,8,btn)
        List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,6,btn)

        local tabIcon
        if c2.Icon then
            tabIcon=MakeIcon(c2.Icon,14,theme.TextMuted,btn)
            if tabIcon then tabIcon.LayoutOrder=0 end
        end

        local titleLbl=New("TextLabel",{
            Size=UDim2.fromOffset(0,32),AutomaticSize=Enum.AutomaticSize.X,
            BackgroundTransparency=1,Text=c2.Title or "Tab",
            TextColor3=theme.TextMuted,TextSize=13,Font=Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,Parent=btn
        })

        -- Page
        local page=New("ScrollingFrame",{
            Name="Page_"..(c2.Title or "Tab"),Size=UDim2.fromScale(1,1),
            BackgroundTransparency=1,ScrollBarThickness=3,
            ScrollBarImageColor3=theme.Border,ScrollingDirection=Enum.ScrollingDirection.Y,
            CanvasSize=UDim2.fromScale(0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=false,Parent=content
        })
        Pad(10,10,10,10,page)
        List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Top,6,page)

        btn.MouseEnter:Connect(function()
            if activeTab and activeTab._btn==btn then return end
            Tween(btn,{BackgroundColor3=theme.TabHover,BackgroundTransparency=0},0.15)
            Tween(titleLbl,{TextColor3=theme.Text},0.15)
        end)
        btn.MouseLeave:Connect(function()
            if activeTab and activeTab._btn==btn then return end
            Tween(btn,{BackgroundTransparency=1},0.15)
            Tween(titleLbl,{TextColor3=theme.TextMuted},0.15)
        end)

        local tobj={_btn=btn,_page=page,_titleLbl=titleLbl,_theme=theme}
        btn.MouseButton1Click:Connect(function() SwitchTab(tobj) end)

        if searchBox then
            searchBox:GetPropertyChangedSignal("Text"):Connect(function()
                local q=searchBox.Text:lower()
                local ti=(c2.Title or ""):lower()
                btn.Visible=q=="" or ti:find(q,1,true)~=nil
            end)
        end

        table.insert(tabs,tobj)
        if #tabs==1 then SwitchTab(tobj) end

        -- ─── ELEMENT BUILDERS ────────────────────────────────
        local Tab={}

        local function EF(parent,h)
            local f=New("Frame",{
                Size=UDim2.new(1,0,0,h or 36),BackgroundColor3=theme.Surface,Parent=parent or page
            })
            Corner(8,f); Stroke(1,theme.Border,0,f); return f
        end

        -- ── BUTTON ──────────────────────────────────────────
        function Tab:Button(c3)
            c3=c3 or {}
            local h=c3.Desc and 52 or 36
            local f=EF(page,h); Pad(0,0,12,12,f)
            List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,8,f)
            if c3.Icon and c3.Icon~="" then MakeIcon(c3.Icon,15,theme.Accent,f) end
            local th2=New("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Parent=f})
            New("TextLabel",{
                Size=UDim2.new(1,0,0,c3.Desc and 18 or 36),BackgroundTransparency=1,
                Text=c3.Title or "Button",TextColor3=theme.Text,TextSize=13,
                Font=Enum.Font.GothamSemibold,TextXAlignment=Enum.TextXAlignment.Left,Parent=th2
            })
            if c3.Desc then
                New("TextLabel",{
                    Size=UDim2.new(1,0,0,16),Position=UDim2.fromOffset(0,20),
                    BackgroundTransparency=1,Text=c3.Desc,TextColor3=theme.TextMuted,
                    TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=th2
                })
            end
            local cl=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=f.ZIndex+1,Parent=f})
            cl.MouseEnter:Connect(function() Tween(f,{BackgroundColor3=theme.SurfaceAlt},0.15) end)
            cl.MouseLeave:Connect(function() Tween(f,{BackgroundColor3=theme.Surface},0.15) end)
            cl.MouseButton1Click:Connect(function()
                Ripple(f,theme)
                if c3.Callback then c3.Callback() end
            end)
            local obj={}
            function obj:Highlight()
                Tween(f,{BackgroundColor3=theme.Accent},0.15)
                task.wait(0.3); Tween(f,{BackgroundColor3=theme.Surface},0.3)
            end
            return obj
        end

        -- ── TOGGLE ──────────────────────────────────────────
        function Tab:Toggle(c3)
            c3=c3 or {}
            local val=c3.Value or false
            local h=c3.Desc and 52 or 36
            local f=EF(page,h); Pad(0,0,12,12,f)
            List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,8,f)
            if c3.Icon then MakeIcon(c3.Icon,15,theme.Accent,f) end
            local th2=New("Frame",{Size=UDim2.new(1,-52,1,0),BackgroundTransparency=1,Parent=f})
            New("TextLabel",{
                Size=UDim2.new(1,0,0,c3.Desc and 18 or 36),BackgroundTransparency=1,
                Text=c3.Title or "Toggle",TextColor3=theme.Text,TextSize=13,
                Font=Enum.Font.GothamSemibold,TextXAlignment=Enum.TextXAlignment.Left,Parent=th2
            })
            if c3.Desc then
                New("TextLabel",{
                    Size=UDim2.new(1,0,0,16),Position=UDim2.fromOffset(0,20),
                    BackgroundTransparency=1,Text=c3.Desc,TextColor3=theme.TextMuted,
                    TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=th2
                })
            end
            local isCb=c3.Type=="Checkbox"
            local track,knob
            if isCb then
                track=New("Frame",{Size=UDim2.fromOffset(18,18),BackgroundColor3=val and theme.ToggleOn or theme.ToggleOff,Parent=f})
                Corner(4,track); Stroke(1.5,theme.Border,0,track)
                knob=New("ImageLabel",{
                    Size=UDim2.fromOffset(12,12),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.fromScale(.5,.5),
                    BackgroundTransparency=1,Image=Icons["check"] or "",
                    ImageColor3=theme.Text,ImageTransparency=val and 0 or 1,Parent=track
                })
            else
                track=New("Frame",{Size=UDim2.fromOffset(40,22),BackgroundColor3=val and theme.ToggleOn or theme.ToggleOff,Parent=f})
                Corner(11,track)
                knob=New("Frame",{
                    Size=UDim2.fromOffset(16,16),
                    Position=val and UDim2.fromOffset(21,3) or UDim2.fromOffset(3,3),
                    BackgroundColor3=theme.Text,Parent=track
                })
                Corner(8,knob)
            end
            local cl=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=f.ZIndex+1,Parent=f})
            local function upd()
                if isCb then
                    Tween(track,{BackgroundColor3=val and theme.ToggleOn or theme.ToggleOff},0.2)
                    Tween(knob,{ImageTransparency=val and 0 or 1},0.15)
                else
                    Tween(track,{BackgroundColor3=val and theme.ToggleOn or theme.ToggleOff},0.2)
                    Tween(knob,{Position=val and UDim2.fromOffset(21,3) or UDim2.fromOffset(3,3)},0.2)
                end
            end
            cl.MouseButton1Click:Connect(function() val=not val; upd(); if c3.Callback then c3.Callback(val) end end)
            local obj={}
            function obj:Set(v) val=v; upd(); if c3.Callback then c3.Callback(val) end end
            function obj:Get() return val end
            return obj
        end

        -- ── SLIDER ──────────────────────────────────────────
        function Tab:Slider(c3)
            c3=c3 or {}
            local vc=c3.Value or {Min=0,Max=100,Default=50}
            local mn,mx,cur,st=vc.Min or 0,vc.Max or 100,vc.Default or 0,c3.Step or 1
            local h=c3.Desc and 60 or 48
            local f=EF(page,h); Pad(0,0,12,12,f)
            New("TextLabel",{
                Size=UDim2.new(1,-60,0,16),Position=UDim2.fromOffset(0,6),
                BackgroundTransparency=1,Text=c3.Title or "Slider",TextColor3=theme.Text,
                TextSize=13,Font=Enum.Font.GothamSemibold,TextXAlignment=Enum.TextXAlignment.Left,Parent=f
            })
            local vl=New("TextLabel",{
                Size=UDim2.fromOffset(50,16),Position=UDim2.new(1,-50,0,6),
                BackgroundTransparency=1,Text=tostring(cur),TextColor3=theme.Accent,
                TextSize=12,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,Parent=f
            })
            if c3.Desc then
                New("TextLabel",{
                    Size=UDim2.new(1,0,0,14),Position=UDim2.fromOffset(0,24),
                    BackgroundTransparency=1,Text=c3.Desc,TextColor3=theme.TextMuted,
                    TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=f
                })
            end
            local ty=c3.Desc and 48 or 36
            local trk=New("Frame",{Size=UDim2.new(1,0,0,6),Position=UDim2.new(0,0,0,ty),BackgroundColor3=theme.ToggleOff,Parent=f})
            Corner(3,trk)
            local fill=New("Frame",{Size=UDim2.new((cur-mn)/(mx-mn),0,1,0),BackgroundColor3=theme.SliderFill,Parent=trk})
            Corner(3,fill)
            New("UIGradient",{Color=ColorSequence.new(theme.GradientA,theme.GradientB),Parent=fill})
            local dot=New("Frame",{
                Size=UDim2.fromOffset(14,14),AnchorPoint=Vector2.new(.5,.5),
                Position=UDim2.new((cur-mn)/(mx-mn),0,.5,0),BackgroundColor3=theme.Text,Parent=trk
            })
            Corner(7,dot); Stroke(2,theme.Accent,0,dot)
            local ds=false
            local function upd(ix)
                local r=math.clamp((ix-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
                local raw=mn+r*(mx-mn)
                cur=math.clamp(math.floor(raw/st+.5)*st,mn,mx)
                local p=(cur-mn)/(mx-mn)
                Tween(fill,{Size=UDim2.new(p,0,1,0)},0.05)
                Tween(dot,{Position=UDim2.new(p,0,.5,0)},0.05)
                vl.Text=tostring(cur)
                if c3.Callback then c3.Callback(cur) end
            end
            trk.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    ds=true; upd(i.Position.X)
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if ds and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then upd(i.Position.X) end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then ds=false end
            end)
            local obj={}
            function obj:Set(v)
                cur=math.clamp(v,mn,mx)
                local p=(cur-mn)/(mx-mn)
                fill.Size=UDim2.new(p,0,1,0); dot.Position=UDim2.new(p,0,.5,0); vl.Text=tostring(cur)
            end
            function obj:Get() return cur end
            return obj
        end

        -- ── INPUT ───────────────────────────────────────────
        function Tab:Input(c3)
            c3=c3 or {}
            local isTA=c3.Type=="Textarea"
            local h=isTA and 78 or (c3.Desc and 52 or 36)
            local f=EF(page,h); Pad(0,0,12,12,f)
            if not isTA then
                List(Enum.FillDirection.Horizontal,Enum.HorizontalAlignment.Left,Enum.VerticalAlignment.Center,8,f)
                if c3.Icon then MakeIcon(c3.Icon,15,theme.Accent,f) end
                local th2=New("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Parent=f})
                if c3.Title then
                    New("TextLabel",{
                        Size=UDim2.new(1,0,0,c3.Desc and 18 or 36),BackgroundTransparency=1,
                        Text=c3.Title,TextColor3=theme.Text,TextSize=13,
                        Font=Enum.Font.GothamSemibold,TextXAlignment=Enum.TextXAlignment.Left,Parent=th2
                    })
                end
                if c3.Desc then
                    New("TextLabel",{
                        Size=UDim2.new(1,0,0,16),Position=UDim2.fromOffset(0,20),
                        BackgroundTransparency=1,Text=c3.Desc,TextColor3=theme.TextMuted,
                        TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=th2
                    })
                end
                local ib=New("TextBox",{
                    Size=UDim2.fromOffset(120,26),AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,0,.5,0),
                    BackgroundColor3=theme.SurfaceAlt,Text=c3.Default or "",
                    PlaceholderText=c3.Placeholder or "Enter...",TextColor3=theme.Text,
                    PlaceholderColor3=theme.TextDisabled,TextSize=12,Font=Enum.Font.Gotham,
                    ClearTextOnFocus=false,Parent=f
                })
                Corner(6,ib); Stroke(1,theme.Border,0,ib); Pad(0,0,8,8,ib)
                ib.FocusLost:Connect(function() if c3.Callback then c3.Callback(ib.Text) end end)
                ib:GetPropertyChangedSignal("Text"):Connect(function()
                    if c3.Changed then c3.Changed(ib.Text) end
                end)
                local obj={}
                function obj:Set(v) ib.Text=v end
                function obj:Get() return ib.Text end
                return obj
            else
                New("TextLabel",{
                    Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text=c3.Title or "Input",
                    TextColor3=theme.Text,TextSize=13,Font=Enum.Font.GothamSemibold,
                    TextXAlignment=Enum.TextXAlignment.Left,Parent=f
                })
                local ta=New("TextBox",{
                    Size=UDim2.new(1,0,1,-22),Position=UDim2.fromOffset(0,22),
                    BackgroundColor3=theme.SurfaceAlt,Text=c3.Default or "",
                    PlaceholderText=c3.Placeholder or "Enter text...",TextColor3=theme.Text,
