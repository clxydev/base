    -- ── Config Manager ───────────────────────────────────────
    Window.ConfigManager=(function()
        local CM={}; local folder=cfg.Folder or "OlympusUI"; local flags={}
        pcall(function() if not isfolder(folder) then makefolder(folder) end end)
        function CM:Config(name)
            local c={}
            function c:Save()
                local data={}
                for flag,obj in pairs(flags) do pcall(function() data[flag]=tostring(obj:Get()) end) end
                pcall(function() writefile(folder.."/"..name..".json",HttpService:JSONEncode(data)) end)
                return true
            end
            function c:Load()
                local ok,raw=pcall(readfile,folder.."/"..name..".json")
                if not ok then return false end
                return true
            end
            return c
        end
        function CM:AllConfigs()
            local list={}
            pcall(function() for _,f in ipairs(listfiles(folder)) do local n=f:match("([^/\\]+)%.json$"); if n then table.insert(list,n) end end end)
            return list
        end
        function CM:RegisterFlag(flag,obj) flags[flag]=obj end
        return CM
    end)()

    -- ── Window methods ────────────────────────────────────────
    function Window:SetTheme(name)
        theme=Themes[name] or theme
        self:Notify({Title="OlympusUI",Content="Theme: "..name,Icon="palette",Duration=2,Theme=name})
    end

    function Window:Destroy()
        Tween(mainF,{BackgroundTransparency=1},0.2); task.wait(0.25); sg:Destroy()
    end

    function Window:SelectTab(i)
        if tabs[i] then SwitchTab(tabs[i]) end
    end

    function Window:Notify(c2)
        OlympusUI:Notify(c2)
    end

    -- Animate in
    mainF.BackgroundTransparency=1
    Tween(mainF,{BackgroundTransparency=0},0.35)

    table.insert(OlympusUI.Windows, Window)
    return Window
end

return OlympusUI

